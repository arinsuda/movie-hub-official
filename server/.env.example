# Server Environment Variables Example

PORT=8080
APP_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGIN=http://localhost:5173

# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=moviehub

# JWT Secrets
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# TMDB API
THE_MOVIE_BASE_API=https://api.themoviedb.org/3
THE_MOVIE_API_KEY=your_tmdb_api_key_here

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=secret
SMTP_FROM=noreply@example.com

# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=remov-private
MINIO_USE_SSL=false

# Google OAuth 2.0 Configuration
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback
GOOGLE_FRONTEND_SUCCESS_URL=http://localhost:5173/
GOOGLE_FRONTEND_ERROR_URL=http://localhost:5173/login
